{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "Local Discord Bridge",
  "browser_specific_settings": {
    "gecko": {
      "id": "local-discord-bridge@cindiekinzz.dev"
    }
  },
  "version": "0.6.0",
  "description": "Give your ChatGPT or Gemini companion real Discord hands. Runs locally — no proxy, no tunnel, no third party.",
  "host_permissions": [
    "*://*.chatgpt.com/*",
    "*://*.chat.openai.com/*",
    "*://*.gemini.google.com/*",
    "http://localhost/*",
    "http://localhost:8081/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:8081/*"
  ],
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "icons": {
    "34": "icon-34.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chatgpt.com/*",
        "*://*.chat.openai.com/*"
      ],
      "js": [
        "content/index.iife.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.gemini.google.com/*"
      ],
      "js": [
        "content/index.iife.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "*.js",
        "*.css",
        "content/*.css",
        "*.svg",
        "icon-128.png",
        "icon-34.png"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}