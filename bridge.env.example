# Local Discord Bridge — runtime config
#
# 1. Copy this file to `bridge.env` (no extension prefix) in the same directory.
# 2. Paste your Discord bot token below (no quotes, no spaces around `=`).
# 3. Get the token from https://discord.com/developers/applications -> your app
#    -> Bot -> Reset Token.

DISCORD_TOKEN=

# Optional: port the bridge listens on. The extension is hardcoded to expect
# 8080, so only change this if you also rebuild the extension with a matching
# URL in extension/chrome-extension/src/mcpclient/config/defaults.ts.
MCP_DISCORD_PORT=8080
